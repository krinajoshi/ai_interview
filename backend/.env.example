# AI Interview Platform - Environment Variables Example
# Copy this file to .env and fill in your own values

# Server Settings
HOST=0.0.0.0
PORT=8000
DEBUG_MODE=True  # Set to False in production

# Security
SECRET_KEY=your_secret_key_here  # Generate a strong random key
ACCESS_TOKEN_EXPIRE_MINUTES=11520  # 8 days

# Database
MONGODB_URL=mongodb://localhost:27017/ai_interview_db
MONGODB_DB_NAME=ai_interview_db

# LLM Settings
# Default model configuration - Hugging Face
LLM_MODEL=huggingface/mistral

# Hugging Face settings (for free API)
HUGGINGFACE_API_TOKEN=your_huggingface_token_here  # Get from https://huggingface.co/settings/tokens
HUGGINGFACE_ENDPOINT=https://api-inference.huggingface.co/models/mistralai/Mistral-7B-Instruct-v0.2

# Speech-to-Text Settings
SPEECH_TO_TEXT_PROVIDER=huggingface  # Options: huggingface, assembly_ai
SPEECH_TO_TEXT_ENDPOINT=https://api-inference.huggingface.co/models/openai/whisper-large-v3

# Optional: Assembly AI for speech recognition fallback
# ASSEMBLY_AI_API_KEY=your_assembly_ai_key_here

# AWS Credentials (for file storage and facial recognition)
# Only needed if using AWS services
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name

# Redis (for rate limiting and caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_SSL=False  # Set to True if using Redis Cloud or other SSL-enabled Redis service

# CORS Settings
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8000"] 